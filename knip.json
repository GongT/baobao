{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"tags": ["-lintignore"],
	"entry": ["**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}", "**/*.*"],
	"project": ["**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}"],
	"ignoreDependencies": [".*-rig", "@types/.*", "@mpis/esbuild", "esbuild"],
	"ignoreBinaries": ["internal-.*", "mpis-.*", "cnpm", "systemd-.*", "systemctl", "journalctl", "unshare"],
	"exclude": ["duplicates", "unresolved"],
	"workspaces": {
		".": {
			"entry": ["**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}", "**/*.*"],
			"project": ["**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}"]
		}
	}
}
