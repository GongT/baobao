{
	"name": "@idlebox/terminal-control",
	"type": "module",
	"version": "0.0.5",
	"description": "Terminal control (clear screen, cursor control, progress bars, etc.)",
	"keywords": [],
	"exports": {
		".": {
			"types": "./src/api.ts",
			"source": "./src/api.ts",
			"default": "./lib/api.js"
		},
		"./default": {
			"types": "./src/default-instance.ts",
			"source": "./src/default-instance.ts",
			"default": "./lib/default-instance.js"
		},
		"./host": {
			"types": "./src/host-instance.ts",
			"source": "./src/host-instance.ts",
			"default": "./lib/host-instance.js"
		},
		"./constants": {
			"types": "./src/constants.ts",
			"source": "./src/constants.ts",
			"default": "./lib/constants.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"prepublishHook": "internal-prepublish-hook",
		"prepack": "mpis-run build --clean",
		"build": "mpis-run build",
		"watch": "mpis-run watch",
		"clean": "mpis-run clean",
		"lint": "internal-lint",
		"prepublishOnly": "internal-prepublish-deny"
	},
	"dependencies": {
		"@idlebox/common": "workspace:^"
	},
	"devDependencies": {
		"@internal/local-rig": "workspace:^",
		"@types/node": "^25.5.0",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"typescript": "^5.8.2"
	},
	"publishConfig": {
		"packCommand": ["publisher", "pack"]
	},
	"sideEffects": false
}
