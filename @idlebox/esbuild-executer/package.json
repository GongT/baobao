{
	"name": "@idlebox/esbuild-executer",
	"description": "A simple script to execute typescript file during development.",
	"version": "0.0.19",
	"type": "module",
	"bin": {
		"es-node": "./loader/bin.js"
	},
	"engines": {
		"node": ">=18.19.0 < 20 || >=20.6.0"
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./loader/index.devel.js"
		},
		"./register": "./lib/hook-worker.js",
		"./lib/hook-worker.js": "./lib/hook-worker.js",
		"./package.json": "./package.json"
	},
	"keywords": ["typescript", "esbuild", "executer", "runner"],
	"scripts": {
		"prepack": "rimraf lib && mpis-tsc -p src",
		"build": "mpis-tsc -p src",
		"watch": "mpis-tsc -p src -w",
		"clean": "rimraf lib",
		"prepublishHook": "internal-prepublish-hook",
		"lint": "internal-lint",
		"prepublishOnly": "internal-prepublish-deny",
		"test": "DEBUG=executer* node --enable-source-maps test/index.js"
	},
	"dependencies": {
		"@idlebox/common": "workspace:^",
		"@idlebox/node": "workspace:^",
		"@idlebox/source-map-support": "workspace:^",
		"debug": "^4.4.3",
		"esbuild": "=0.27.3",
		"execa": "^9.6.1",
		"import-meta-resolve": "^4.2.0",
		"source-map-js": "^1.2.1",
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@internal/local-rig": "workspace:^",
		"@mpis/typescript": "workspace:^",
		"@types/node": "^25.5.0",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.2",
		"why-is-node-running": "^3.2.2"
	},
	"publishConfig": {
		"packCommand": ["publisher", "pack"]
	},
	"sideEffects": false
}
