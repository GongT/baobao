{
	"name": "@idlebox/native-executer",
	"description": "A simple script to execute typescript file during development.",
	"version": "0.0.23",
	"type": "module",
	"exports": {
		".": "./lib/exports.js",
		"./register": {
			"types": "./src/register-if-not.ts",
			"default": "./lib.devel/register-if-not.js"
		},
		"./register/respawn": {
			"types": "./src/register-or-respawn.ts",
			"default": "./lib.devel/register-or-respawn.js"
		},
		"./package.json": "./package.json"
	},
	"imports": {
		"#generate-prefix": "./lib/generate-prefix.js"
	},
	"keywords": ["typescript", "executer", "runner"],
	"scripts": {
		"prepublishHook:update-exports": "./scripts/update-exports.js",
		"prepublishHook": "internal-prepublish-hook",
		"prepack": "mpis-run build --clean",
		"build": "mpis-run build",
		"watch": "mpis-run watch",
		"clean": "mpis-run clean",
		"lint": "internal-lint",
		"prepublishOnly": "internal-prepublish-deny",
		"test": "DEBUG=executer* node --enable-source-maps test/index.js"
	},
	"dependencies": {
		"debug": "^4.4.3",
		"execa": "^9.6.1",
		"import-meta-resolve": "^4.2.0"
	},
	"devDependencies": {
		"amaro": "^1.1.10",
		"@internal/local-rig": "workspace:^",
		"@mpis/esbuild": "workspace:^",
		"@types/node": "^25.5.0",
		"esbuild": "^0.27.3",
		"typescript": "^6.0.2"
	},
	"publishConfig": {
		"packCommand": ["publisher", "pack"]
	},
	"sideEffects": false
}
