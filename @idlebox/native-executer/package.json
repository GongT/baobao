{
	"name": "@idlebox/native-executer",
	"description": "A simple script to execute typescript file during development.",
	"version": "0.0.18",
	"type": "module",
	"engines": {
		"node": ">=18.19.0 < 20 || >=20.6.0"
	},
	"exports": {
		".": "./src/index.ts",
		"./register": "./src/register.ts",
		"./loader": "./src/loader.hooks.ts",
		"./package.json": "./package.json"
	},
	"keywords": ["typescript", "executer", "runner"],
	"scripts": {
		"prepack": "rimraf lib && mpis-tsc -p src",
		"build": "mpis-tsc -p src --noEmit",
		"watch": "mpis-tsc -p src -w --noEmit",
		"clean": "rimraf lib",
		"prepublishHook": "internal-prepublish-hook",
		"lint": "internal-lint",
		"prepublishOnly": "internal-prepublish-deny",
		"test": "DEBUG=executer* node --enable-source-maps test/index.js"
	},
	"dependencies": {
		"debug": "^4.4.3",
		"execa": "^9.6.1",
		"import-meta-resolve": "^4.2.0",
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@internal/local-rig": "workspace:^",
		"@mpis/typescript": "workspace:^",
		"@types/node": "^25.5.0",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.2"
	},
	"publishConfig": {
		"packCommand": ["publisher", "pack"]
	},
	"sideEffects": false
}
