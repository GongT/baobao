{
	"name": "@idlebox/node",
	"type": "module",
	"version": "1.4.30",
	"exports": {
		".": {
			"esbuild": {
				"early-loader": "./src/early-loader.devel.ts",
				"generate": "./src/generate.devel.ts"
			},
			"source": "./src/autoindex.generated.ts",
			"default": "./lib/autoindex.generated.js"
		},
		"./test": "./ne.ts",
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"scripts": {
		"prepublishHook": "internal-prepublish-hook",
		"prepack": "mpis-run build --clean",
		"build": "mpis-run build",
		"watch": "mpis-run watch",
		"clean": "mpis-run clean",
		"lint": "internal-lint",
		"prepublishOnly": "internal-prepublish-deny"
	},
	"dependencies": {
		"@idlebox/common": "workspace:^",
		"@idlebox/errors": "workspace:^",
		"execa": "^9.6.1"
	},
	"devDependencies": {
		"@build-script/baseline-rig": "workspace:^",
		"@build-script/autoindex": "workspace:^",
		"@mpis/run": "workspace:^",
		"@internal/local-rig": "workspace:^",
		"@types/node": "^25.5.0"
	},
	"decoupledDependencies": "dev",
	"publishConfig": {
		"packCommand": ["publisher", "pack"]
	}
}
