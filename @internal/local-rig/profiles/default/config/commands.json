{
	"$schema": "../../../node_modules/@mpis/run/commands.schema.json",
	"commands": {
		"autoindex": {
			"title": "Automatic Indexing",
			"command": {
				"package": "@build-script/autoindex",
				"binary": "autoindex",
				"arguments": ["--config"],
			},
		},

		/**
		 *
		 */
		"codegen": {
			"title": "Code Generation",
			"command": {
				"package": "@build-script/codegen",
				"binary": "codegen",
				"arguments": ["src"],
			},
		},

		/**
		 *
		 */
		"codegen:production": {
			"title": "Code Generation (Production)",
			"command": {
				"package": "@build-script/codegen",
				"binary": "loader/bin.js",
				"arguments": ["src"],
			},
		},

		/**
		 *
		 */
		"depcheck": {
			"title": "Check Dependencies",
			"command": {
				"package": "@build-script/depcheck",
				"binary": "depcheck",
			},
		},

		/**
		 *
		 */
		"typescript": {
			"title": "Compile TypeScript",
			"command": {
				"package": "@mpis/typescript",
				"binary": "mpis-tsc",
			},
			"watch": ["-w"],
			"cwd": ".",
			"env": {},
		},
	},
	"clean": ["lib"],
}
