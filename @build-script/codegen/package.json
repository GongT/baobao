{
	"name": "@build-script/codegen",
	"type": "module",
	"version": "1.0.26",
	"bin": {
		"codegen": "./loader/bin.devel.js"
	},
	"exports": {
		".": {
			"types": "./src/plugin.ts",
			"source": "./src/plugin.ts",
			"default": "./lib/plugin.js"
		},
		"./package.json": "./package.json"
	},
	"imports": {
		"#self-reference": "./loader/plugin.devel.js"
	},
	"scripts": {
		"prepublishHook": "internal-prepublish-hook",
		"prepack": "mpis-run build --clean",
		"build": "mpis-run build",
		"watch": "mpis-run watch",
		"clean": "mpis-run clean",
		"lint": "internal-lint",
		"prepublishOnly": "internal-prepublish-deny"
	},
	"dependencies": {
		"@idlebox/args": "workspace:^",
		"@idlebox/chokidar": "workspace:^",
		"@idlebox/common": "workspace:^",
		"@idlebox/json-extends-loader": "workspace:^",
		"@idlebox/logger": "workspace:^",
		"@idlebox/native-executer": "workspace:^",
		"@idlebox/node": "workspace:^",
		"@idlebox/source-map-support": "workspace:^",
		"@mpis/client": "workspace:^",
		"execa": "^9.6.1",
		"glob": "^13.0.6",
		"minimatch": "^10.2.4",
		"tiny-async-pool": "^2.1.0"
	},
	"devDependencies": {
		"@internal/local-rig": "workspace:^",
		"@types/node": "^25.5.0",
		"@types/source-map": "npm:source-map@^0.6.1",
		"typescript": "^6.0.2"
	},
	"publishConfig": {
		"packCommand": ["publisher", "pack"]
	},
	"sideEffects": false
}
